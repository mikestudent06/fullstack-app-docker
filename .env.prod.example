# Production environment — copy to .env.prod (gitignored)
# Used by: docker compose -f docker-compose.prod.yml --env-file .env.prod up

# Docker Hub (for pulling published images on a server)
DOCKERHUB_USERNAME=your-dockerhub-username
IMAGE_TAG=latest

# Neon
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Production URLs — use your real domain or server IP
CORS_ORIGIN=http://localhost:8080
VITE_API_URL=http://localhost:3000

# Host ports
API_PORT=3000
CLIENT_PORT=8080
